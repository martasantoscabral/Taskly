datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Utilizador {
  id_utilizador Int      @id @default(autoincrement())
  nome          String
  email         String   @unique
  handle        String   @unique
  suspenso      Boolean  @default(false)
  criadoEM      DateTime @default(now())
  password      String
  role          Role     @default(USER)

  grupo UtilizadorGrupo[]

  conflitosFicheiros  ConflitoFicheiros[]
  ficheirosSubmetidos FicheiroSubmetido[]
  mergesCriados       MergeFicheiro[]

  participacoesDesafio DesafioParticipacao[]
  desafiosCriados      Desafio[]

  comentariosFeed     FeedComentario[]
  likesFeed           FeedLike[]
  publicacoesFeed     FeedPublicacao[]
  seguidoresRecebidos Seguidor[]       @relation("UserSeguidores")
  seguindo            Seguidor[]       @relation("UserSeguindo")
  notificacoes        Notificacao[]

  reportsRecebidos Report[]     @relation("Reportado")
  reportsFeitos    Report[]     @relation("ReportadoPor")
  tasks            Task[]
  aiResponses      AiResponse[]
  conversasUser2   Conversas[]

  mensagensGrupo MensagemGrupo[]

  @@map("utilizadores")
}

model Task {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  priority    TaskPriority @default(MEDIA)
  status      TaskStatus   @default(PENDING)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  id_user     Int

  publicacoesFeed FeedPublicacao[]
  reports         Report[]
  subTasks        SubTask[]
  aiResponses     AiResponse[]

  pdfPath String?
  pdfName String?

  user Utilizador @relation(fields: [id_user], references: [id_utilizador])

  id_grupo Int?
  grupo    Grupo? @relation(fields: [id_grupo], references: [grupo_id])

  @@map("task")
}

model SubTask {
  id_subtask      Int              @id @default(autoincrement())
  titulo          String
  concluida       Boolean          @default(false)
  criadoEM        DateTime         @default(now())
  id_tarefa       Int
  publicacoesFeed FeedPublicacao[]
  task            Task             @relation(fields: [id_tarefa], references: [id])

  @@map("subtasks")
}

model AiResponse {
  id        Int      @id @default(autoincrement())
  type      String
  prompt    String
  response  Json
  id_tarefa Int?
  id_user   Int?
  createdAt DateTime @default(now())

  task       Task?       @relation(fields: [id_tarefa], references: [id])
  utilizador Utilizador? @relation(fields: [id_user], references: [id_utilizador])
}

model Notificacao {
  id_notificacao   Int        @id @default(autoincrement())
  id_target        Int
  mensagem         String?
  ficheiro_enviado Int?
  lida             Boolean    @default(false)
  recebida_em      DateTime   @default(now())
  target           Utilizador @relation(fields: [id_target], references: [id_utilizador])

  @@map("notificacoes")
}

model Conversas {
  chat_id     Int        @id @default(autoincrement())
  user2_id    Int
  msg_history String
  user2       Utilizador @relation(fields: [user2_id], references: [id_utilizador])
  updated_At  DateTime   @updatedAt
}

model Desafio {
  id_desafio      Int                   @id @default(autoincrement())
  id_admin        Int
  titulo          String
  data_inicio     DateTime
  data_fim        DateTime
  badge           String
  notificar       Boolean               @default(false)
  concluido       Boolean               @default(false)
  publicado       Boolean               @default(false)
  participacoes   DesafioParticipacao[]
  admin           Utilizador            @relation(fields: [id_admin], references: [id_utilizador])
  publicacoesFeed FeedPublicacao[]

  @@map("desafios")
}

model DesafioParticipacao {
  id_participacao Int        @id @default(autoincrement())
  id_user         Int
  id_desafio      Int
  concluido       Boolean    @default(false)
  desafio         Desafio    @relation(fields: [id_desafio], references: [id_desafio])
  utilizador      Utilizador @relation(fields: [id_user], references: [id_utilizador])

  @@unique([id_user, id_desafio])
  @@map("desafio_participacoes")
}

model Report {
  id_report        Int        @id @default(autoincrement())
  id_reportado_por Int
  id_reportado     Int
  id_tarefa        Int?
  tipo             String
  status           String
  relevancia       String
  data             DateTime   @default(now())
  reportado        Utilizador @relation("Reportado", fields: [id_reportado], references: [id_utilizador])
  reportadoPor     Utilizador @relation("ReportadoPor", fields: [id_reportado_por], references: [id_utilizador])
  tarefa           Task?      @relation(fields: [id_tarefa], references: [id])

  @@map("reports")
}

model FicheiroSubmetido {
  id_ficheiro     Int        @id @default(autoincrement())
  id_user         Int
  nome            String?
  id_tarefa       Int
  nome_ficheiro   String
  file_path       String
  mensagem_commit String?
  criadoEM        DateTime   @default(now())
  utilizador      Utilizador @relation(fields: [id_user], references: [id_utilizador])

  @@map("ficheiros_submetidos")
}

model ConflitoFicheiros {
  id_conflito         Int        @id @default(autoincrement())
  id_tarefa           Int
  nome_ficheiro       String
  id_user             Int
  mensagem_commit     String?
  id_versao_escolhida Int?
  criadoEM            DateTime   @default(now())
  status              String
  utilizador          Utilizador @relation(fields: [id_user], references: [id_utilizador])

  @@map("conflitos_ficheiros")
}

model MergeFicheiro {
  id_merge            Int        @id @default(autoincrement())
  id_tarefa           Int
  criado_por          Int
  tamanho             String
  ficheiros_incluidos String
  criadoEM            DateTime   @default(now())
  utilizador          Utilizador @relation(fields: [criado_por], references: [id_utilizador])

  @@map("merge_ficheiros")
}

model Grupo {
  grupo_id Int      @id @default(autoincrement())
  nome     String
  criadoEm DateTime @default(now())

  membros   UtilizadorGrupo[]
  tasks     Task[]
  mensagens MensagemGrupo[]
}

model UtilizadorGrupo {
  gr_id        Int
  ut_id        Int
  quandoEntrou DateTime          @default(now())
  classe       classe_utilizador @default(MEMBRO)
  grupo        Grupo             @relation(fields: [gr_id], references: [grupo_id])
  utilizador   Utilizador        @relation(fields: [ut_id], references: [id_utilizador])

  @@id([gr_id, ut_id])
}

model FeedPublicacao {
  id_publicacao      Int              @id @default(autoincrement())
  id_user            Int
  id_tarefa          Int?
  id_subtask         Int?
  id_desafio         Int?
  tipo               FeedTipo
  comentario         String?
  quer_participantes Boolean          @default(false)
  badge              String?
  criadoEM           DateTime         @default(now())
  comentarios        FeedComentario[]
  likes              FeedLike[]
  desafio            Desafio?         @relation(fields: [id_desafio], references: [id_desafio])
  subtask            SubTask?         @relation(fields: [id_subtask], references: [id_subtask])
  tarefa             Task?            @relation(fields: [id_tarefa], references: [id])
  utilizador         Utilizador       @relation(fields: [id_user], references: [id_utilizador])

  @@map("feed_publicacoes")
}

model FeedLike {
  id_like       Int            @id @default(autoincrement())
  id_publicacao Int
  id_user       Int
  criadoEM      DateTime       @default(now())
  publicacao    FeedPublicacao @relation(fields: [id_publicacao], references: [id_publicacao])
  utilizador    Utilizador     @relation(fields: [id_user], references: [id_utilizador])

  @@unique([id_publicacao, id_user])
  @@map("feed_likes")
}

model FeedComentario {
  id_comentario Int            @id @default(autoincrement())
  id_publicacao Int
  id_user       Int
  comentario    String
  criadoEM      DateTime       @default(now())
  publicacao    FeedPublicacao @relation(fields: [id_publicacao], references: [id_publicacao])
  utilizador    Utilizador     @relation(fields: [id_user], references: [id_utilizador])

  @@map("feed_comentarios")
}

model Seguidor {
  seguido_id  Int
  seguidor_id Int
  criadoEM    DateTime   @default(now())
  seguido     Utilizador @relation("UserSeguidores", fields: [seguido_id], references: [id_utilizador])
  seguidor    Utilizador @relation("UserSeguindo", fields: [seguidor_id], references: [id_utilizador])

  @@id([seguido_id, seguidor_id])
  @@map("seguidores")
}

enum Role {
  USER
  ADMIN
}

enum TaskPriority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum TaskStatus {
  PENDING
  DOING
  DONE
}

enum classe_utilizador {
  MEMBRO
  LIDER
}

enum FeedTipo {
  TAREFA_EM_PROGRESSO
  TAREFA_CONCLUIDA
  SUBTAREFA_CONCLUIDA
  TAREFA_PARTILHADA
  DESAFIO_CONCLUIDO
  BADGE_RECEBIDO
}

model MensagemGrupo {
  id_mensagem Int      @id @default(autoincrement())
  texto       String
  criadaEm    DateTime @default(now())

  grupo_id Int
  user_id  Int

  grupo      Grupo      @relation(fields: [grupo_id], references: [grupo_id], onDelete: Cascade)
  utilizador Utilizador @relation(fields: [user_id], references: [id_utilizador], onDelete: Cascade)

  @@index([grupo_id])
  @@index([user_id])
  @@map("mensagens_grupo")
}
